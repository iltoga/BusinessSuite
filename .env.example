SECRET_KEY="replace-with-a-random-32-plus-byte-django-secret-key"
# Optional: dedicated JWT signing key (HS256 requires at least 32 bytes).
# If omitted, SECRET_KEY is used.
JWT_SIGNING_KEY=""
DJANGO_SETTINGS_MODULE="business_suite.settings.dev"
DJANGO_LOG_LEVEL="WARNING"
SYSTEM_USER_PASSWORD="your-system-user-password"
SYSTEM_USER_EMAIL="your-system-user-email@example.com"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="your-db-name"
DB_USER="your-db-user"
DB_PASS="your-db-password"
DB_PATH="/path/to/your/db"
# Redis cache + Dramatiq broker + Redis Streams defaults
# For host-run local development, use REDIS_HOST="127.0.0.1" (or "localhost").
# For Dockerized app services, keep REDIS_HOST="redis".
REDIS_URL="redis://bs-redis:6379/1"
REDIS_HOST="bs-redis"
REDIS_PORT="6379"
DRAMATIQ_REDIS_DB="0"
DRAMATIQ_NAMESPACE="dramatiq:queue"
DRAMATIQ_RESULTS_ENABLED="true"
DRAMATIQ_RESULTS_STORE_RESULTS="true"
DRAMATIQ_RESULTS_TTL_MS="300000"
DRAMATIQ_RESULTS_NAMESPACE="dramatiq:results"
# Optional override if you want a dedicated Redis for results.
# DRAMATIQ_RESULTS_REDIS_URL="redis://bs-redis:6379/0"
DRAMATIQ_HIGH_THREADS="8"
DRAMATIQ_LOW_THREADS="2"
DRAMATIQ_HIGH_PROCESSES="1"
DRAMATIQ_LOW_PROCESSES="1"
# Keep as "realtime" for compatibility; set to "doc_conversion" to isolate PDF conversion tasks.
DRAMATIQ_INVOICE_DOC_QUEUE="realtime"
DRAMATIQ_DOC_PROCESSES="1"
DRAMATIQ_DOC_THREADS="1"
# Production docker-compose worker overrides (low-memory VPS defaults)
DRAMATIQ_HIGH_THREADS_WORKER="2"
DRAMATIQ_LOW_THREADS_WORKER="1"
DRAMATIQ_HIGH_PROCESSES_WORKER="1"
DRAMATIQ_LOW_PROCESSES_WORKER="1"
DRAMATIQ_DOC_PROCESSES_WORKER="1"
DRAMATIQ_DOC_THREADS_WORKER="1"

# Production Gunicorn tuning (used by backend/start.sh + docker-compose.yml)
GUNICORN_WORKERS="2"
GUNICORN_THREADS="2"
GUNICORN_TIMEOUT="120"
GUNICORN_MAX_REQUESTS="1200"
GUNICORN_MAX_REQUESTS_JITTER="50"
STREAM_MAXLEN="10000"
STREAM_TTL_SECONDS="604800"
CACHE_KEY_PREFIX="revisbali"
RESET_DB_ON_STARTUP="false"

# Grafana Cloud Loki (required by bs-alloy in production)
# IMPORTANT: URL must include /loki/api/v1/push (otherwise Alloy receives HTTP 405)
GRAFANA_CLOUD_LOKI_URL="https://logs-prod-xxx.grafana.net/loki/api/v1/push"
GRAFANA_CLOUD_LOKI_USER="1234567"
GRAFANA_CLOUD_LOKI_API_KEY="your-grafana-cloud-token"

# When true, the deploy will run full initial seeding (creategroups, populate_*, createsuperuser)
# Use sparingly. Defaults to "false" for normal deployments.
INITIALIZE_DB="false"

# This is the path where your data (db), media, file uploads, logs and other data will be stored
DATA_PATH="/path/to/your/data"
APP_DOMAIN="your-app-domain.com"
ADMIN_DOMAIN="admin.your-app-domain.com"
# Optional: set to the parent domain (for example, revisbali.com) only when
# cookies must be shared across sibling subdomains such as crm.* and crmadmin.*.
COOKIE_DOMAIN=""

# default username email and password
SITE_ADMIN_USERNAME="your-default-username"
SITE_ADMIN_EMAIL="your-default-email@example.com"
SITE_ADMIN_PASSWORD="your-default-password"

# Firebase Cloud Messaging (Web Push)
GOOGLE_FCM_SERVICE_ACCOUNT_FILE="path/to/firebase-service-account.json"
FCM_PROJECT_ID="your-firebase-project-id"
FCM_PROJECT_NUMBER="your-firebase-project-number"
FCM_SENDER_ID="your-firebase-project-number"
FCM_VAPID_PUBLIC_KEY="your-vapid-public-key"
FCM_WEB_API_KEY="your-firebase-web-api-key"
FCM_WEB_APP_ID="your-firebase-web-app-id"
FCM_WEB_AUTH_DOMAIN="your-project.firebaseapp.com"
FCM_WEB_STORAGE_BUCKET="your-project.appspot.com"

# Cloud Storage settings (for media files, backups, etc.)
USE_CLOUD_STORAGE="True"
AWS_ACCESS_KEY_ID="example-access-key-id"
AWS_SECRET_ACCESS_KEY="example-secret-access-key"
AWS_STORAGE_BUCKET_NAME="crmrevisbalidev"
AWS_S3_ENDPOINT_URL="https://<<your-account-id>>.r2.cloudflarestorage.com"
AWS_S3_REGION_NAME="auto"
AWS_S3_SIGNATURE_VERSION="s3v4"
AWS_S3_ADDRESSING_STYLE="virtual"
AWS_QUERYSTRING_AUTH="True"
AWS_QUERYSTRING_EXPIRE="3600"
AWS_DBBACKUP_LOCATION="backups"
# For production set AWS_STORAGE_BUCKET_NAME="crmrevisbali"
# Optional: Custom Domain if you have one
# AWS_S3_CUSTOM_DOMAIN=`static.revisbali.com`

# Optional restore-source overrides:
# use these when restoring a DB backup into a different environment/bucket and media
# must be copied from the source object storage referenced in backup manifest.json.
# RESTORE_SOURCE_AWS_ACCESS_KEY_ID="source-access-key-id"
# RESTORE_SOURCE_AWS_SECRET_ACCESS_KEY="source-secret-access-key"
# RESTORE_SOURCE_AWS_STORAGE_BUCKET_NAME="source-bucket-name"
# RESTORE_SOURCE_AWS_S3_ENDPOINT_URL="https://<<source-account-id>>.r2.cloudflarestorage.com"
# RESTORE_SOURCE_AWS_S3_REGION_NAME="auto"
# RESTORE_SOURCE_AWS_S3_SIGNATURE_VERSION="s3v4"
# RESTORE_SOURCE_AWS_S3_ADDRESSING_STYLE="virtual"
# RESTORE_SOURCE_AWS_LOCATION=""

# Use this token for authenticating against the Cloudflare API (https://developers.cloudflare.com/api/)
CLOUDFLARE_TOKEN_VALUE="example-cloudflare-token"

# LLM settings
# Available providers: openrouter | openai | groq
LLM_PROVIDER="openrouter"
# Global default model for non-groq providers. Ignored when LLM_PROVIDER="groq".
LLM_DEFAULT_MODEL="google/gemini-3-flash-preview"
# Default model used when LLM_PROVIDER="groq".
GROQ_DEFAULT_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
# Optional provider-specific defaults used by failover routing.
# OPENROUTER_DEFAULT_MODEL="google/gemini-2.5-flash-lite"
# OPENAI_DEFAULT_MODEL="gpt-5-mini"

# Dedicated model overrides for OpenRouter-only operation.
# When provider is not openrouter these values automatically fall back to LLM_DEFAULT_MODEL.
# IMPORTANT: models must support image input (vision).
# Example: DOCUMENT_CATEGORIZER_MODEL="google/gemini-2.5-flash-lite"
# DOCUMENT_CATEGORIZER_MODEL=""
# Example: DOCUMENT_CATEGORIZER_MODEL_HIGH="google/gemini-3-flash-preview"
# DOCUMENT_CATEGORIZER_MODEL_HIGH=""
# Dedicated model for document validation (positive/negative prompt analysis).
# Example: DOCUMENT_VALIDATOR_MODEL="google/gemini-3-flash-preview"
# DOCUMENT_VALIDATOR_MODEL=""
# Dedicated model for passport uploadability checks.
# Example: CHECK_PASSPORT_MODEL="google/gemini-3-flash-preview"
# CHECK_PASSPORT_MODEL=""
CHECK_PASSPORT_AI_MIN_CONFIDENCE_FOR_UPLOAD="0.95"

# Provider failover router:
# - If primary provider fails with retriable errors (rate-limit, timeout, etc.),
#   fallback providers are attempted in this order.
# - Sticky fallback provider is cached globally for 1 hour by default.
LLM_AUTO_FALLBACK_ENABLED="true"
# Example: "openrouter" (default when LLM_PROVIDER="groq"), or "openrouter,openai"
# LLM_FALLBACK_PROVIDER_ORDER=""
LLM_FALLBACK_STICKY_SECONDS="3600"
LLM_FALLBACK_STICKY_CACHE_KEY="ai:router:sticky_provider"

OPENROUTER_API_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_TIMEOUT="120.0"
OPENAI_TIMEOUT="120.0"

# Per-request timeout (seconds) for each categorization AI call.
DOCUMENT_CATEGORIZATION_TIMEOUT="30"
# Per-request timeout (seconds) for each validation AI call.
DOCUMENT_VALIDATION_TIMEOUT="30"

# Delay in milliseconds for debouncing skeleton loading state in the frontend. Adjust as needed to balance perceived performance and UI stability.
SKELETON_DEBOUNCE_DURATION_MS="500"