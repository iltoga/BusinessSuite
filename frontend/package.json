{
  "name": "business-suite-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:lan": "ng serve --host 0.0.0.0 --port 4200 --ssl false --allowed-hosts --proxy-config proxy.conf.json",
    "start_public": "bun run start:lan",
    "serve:static": "bun server-static.js",
    "build": "NG_BUILD=true ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:unit": "ng test --watch=false",
    "test:e2e": "playwright test",
    "serve:ssr:business-suite-frontend": "node dist/business-suite-frontend/server/server.mjs",
    "generate:api": "bunx @openapitools/openapi-generator-cli generate --enable-post-process-file -i ../backend/schema.yaml -g typescript-angular -o src/app/core/api --additional-properties=fileNaming=kebab-case,ngVersion=21,modelPropertyNaming=camelCase && bun scripts/patch-generated-api.ts",
    "generate:api:modern": "bunx @openapitools/openapi-generator-cli generate --enable-post-process-file -i ../backend/schema.yaml -g typescript-angular -o src/app/core/api --additional-properties=fileNaming=kebab-case,ngVersion=21,modelPropertyNaming=camelCase,useSingleRequestParameter=true,withInterfaces=true,stringEnums=true && bun scripts/patch-generated-api.ts",
    "mock:server": "bunx prism mock ../backend/schema.yaml -p 4010 --dynamic -h 0.0.0.0",
    "start:mock": "ng serve --configuration=mock",
    "dev:mock": "concurrently \"bun run mock:server\" \"BACKEND_URL=http://localhost:4010 bun run start:mock\"",
    "update-deps": "bash ../scripts/update-bun-dependencies.sh frontend",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "@angular/ssr": "^21.2.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "lucide-angular": "^0.577.0",
    "marked": "^17.0.5",
    "ng2-charts": "^10.0.0",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "ngx-sonner": "^3.1.0",
    "pdfjs-dist": "^5.5.207",
    "rxjs": "~7.8.2",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1",
    "zard-ui": "^0.0.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@playwright/test": "^1.58.2",
    "@scalar/cli": "^1.7.6",
    "@stoplight/prism-cli": "^5.14.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "angular-eslint": "21.3.1",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.1.1"
  }
}
